model ShortUrl {
  id          Int      @id @default(autoincrement())
  url         String
  shortCode   String   @map("short_code") @unique
  accessCount Int      @map("access_count") @default(0)
  createdAt   DateTime @map("created_at") @default(now())
  updatedAt   DateTime @map("updated_at") @updatedAt

  @@index([shortCode])
  @@map("short_urls")
}
